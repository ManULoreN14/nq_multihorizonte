{
  "version": 2,
  "routes": [
    {
      "src": "/",
      "dest": "/nq-multihor.html"
    },
    {
      "src": "/datos_radar.json",
      "dest": "/datos_radar.json"
    }
  ],
  "headers": [
    {
      "source": "/datos_radar.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
