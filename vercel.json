{
  "version": 2,
  "routes": [
    {
      "src": "/datos_radar.json",
      "dest": "/datos_radar.json",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
