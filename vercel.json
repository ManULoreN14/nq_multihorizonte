{
  "version": 2,
  "rewrites": [
    { "source": "/", "destination": "/nq-multihor.html" },
    { "source": "/datos_radar.json", "destination": "/datos_radar.json" }
  ],
  "headers": [
    {
      "source": "/datos_radar.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}